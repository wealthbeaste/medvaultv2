{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://medvaultv2-production.up.railway.app/api/:path*"
    }
  ],
  "routes": [
    { "src": "/app",             "dest": "/app.html" },
    { "src": "/order",           "dest": "/order.html" },
    { "src": "/admin",           "dest": "/login.html" },
    { "src": "/ai",              "dest": "/ai.html" },
    { "src": "/suppliers",       "dest": "/suppliers.html" },
    { "src": "/supplier-portal", "dest": "/supplier-portal.html" },
    { "src": "/supplier",        "dest": "/supplier-portal.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "X-Content-Type-Options",   "value": "nosniff" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/service-worker.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    },
    {
      "source": "/(.*)\\.html",
      "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
    }
  ]
}
